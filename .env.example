# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-secret

# ── LLM keys (provide at least one) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Locale ────────────────────────────────────────────────────────────────────
TZ=America/Chicago
